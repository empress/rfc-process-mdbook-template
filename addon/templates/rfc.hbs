<div class="page">
  <div class="menu-bar">
    <div class="left-buttons">
      <button class="reset" {{action "toggleSidebar"}}>
        <i class="fa fa-bars" ></i>
      </button>
    </div>
  </div>
  <div class="content">
    <table>
      <thead>
        <tr>
          <td>start Date</td>
          <td>release</td>
          <td>releaseVersions</td>
          <td>PR link</td>
          <td>Stage</td>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>{{model.start}}</td>
          <td>{{model.release}}</td>
          <td>{{releaseVersions}} todo make this less "object"</td>
          <td><a href={{model.rfc}}>RFC Link</a></td>
          <td>{{model.stage}}</td>
        </tr>
      </tbody>
    </table>
    <ul>
      {{#each model.teams as |team|}}
        <li>{{team.title}}</li>
      {{/each}}
    </ul>
    {{html-safe model.html}}
  </div>
</div>

{{#if previousRFC}}
  {{#link-to "rfc" previousRFC class="nav-chapters previous"}}
    <i class="fa fa-angle-left"></i>
  {{/link-to}}
{{else}}
  {{#link-to "index" class="nav-chapters previous"}}<i class="fa fa-angle-left"></i>{{/link-to}}
{{/if}}

{{#if nextRFC}}
  {{#link-to "rfc" nextRFC class="nav-chapters next"}}
    <i class="fa fa-angle-right"></i>
  {{/link-to}}
{{/if}}
